{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/asset.schema.json",
  "title": "Experience Asset",
  "type": "object",
  "required": [
    "asset_id",
    "asset_type",
    "knowledge_scope",
    "knowledge_kind",
    "title",
    "content",
    "scope",
    "source_episode_ids",
    "source_candidate_ids",
    "confidence",
    "status"
  ],
  "properties": {
    "asset_id": { "type": "string" },
    "workspace": { "type": ["string", "null"] },
    "project_id": { "type": ["string", "null"] },
    "source_project": { "type": ["string", "null"] },
    "owning_team": { "type": ["string", "null"] },
    "asset_type": { "type": "string" },
    "knowledge_scope": { "type": "string" },
    "knowledge_kind": { "type": "string" },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["level", "value"],
      "properties": {
        "level": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "source_workspace": { "type": ["string", "null"] },
    "source_episode_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_candidate_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "asset_storage": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "uri": { "type": ["string", "null"] },
        "portable": { "type": "boolean" }
      }
    },
    "retrieval_index": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "collection": { "type": ["string", "null"] },
        "portable": { "type": "boolean" }
      }
    },
    "delivery": {
      "type": "object",
      "properties": {
        "portable": { "type": "boolean" },
        "shareable": { "type": "boolean" },
        "owner": { "type": "string" }
      }
    },
    "confidence": { "type": "number" },
    "status": { "type": "string" },
    "last_used_at": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
