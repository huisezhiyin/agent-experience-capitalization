{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/candidate.schema.json",
  "title": "Candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "source_episode_ids",
    "candidate_type",
    "title",
    "content",
    "reusability_score",
    "stability_score",
    "confidence_score",
    "constraint_value_score",
    "scope",
    "status"
  ],
  "properties": {
    "candidate_id": { "type": "string" },
    "project_id": { "type": ["string", "null"] },
    "source_project": { "type": ["string", "null"] },
    "owning_team": { "type": ["string", "null"] },
    "source_episode_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "candidate_type": { "type": "string" },
    "knowledge_kind": { "type": "string" },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "reusability_score": { "type": "number" },
    "stability_score": { "type": "number" },
    "confidence_score": { "type": "number" },
    "constraint_value_score": { "type": "number" },
    "scope": {
      "type": "object",
      "required": ["level", "value"],
      "properties": {
        "level": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "conflicts_with": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": { "type": "string" },
    "asset_storage": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "uri": { "type": ["string", "null"] },
        "portable": { "type": "boolean" }
      }
    },
    "retrieval_index": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "uri": { "type": ["string", "null"] },
        "collection": { "type": ["string", "null"] },
        "portable": { "type": "boolean" }
      }
    },
    "state_index": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "uri": { "type": ["string", "null"] },
        "portable": { "type": "boolean" }
      }
    },
    "delivery": {
      "type": "object",
      "properties": {
        "portable": { "type": "boolean" },
        "shareable": { "type": "boolean" },
        "owner": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "created_at": { "type": "string" }
  }
}
