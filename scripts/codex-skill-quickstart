#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TARGET_WORKSPACE="${1:-$PWD}"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'USAGE'
Usage:
  scripts/codex-skill-quickstart [target-workspace]

One-command setup for Codex users:
  - creates .venv if needed
  - installs expcap with Milvus Lite support
  - installs the ready-to-use Codex skill
  - enables project instructions for the target workspace
  - runs doctor to verify the save/get/log and retrieval setup

Environment:
  EXPCAP_HOME                 Defaults to $HOME/.expcap.
  EXPCAP_STORAGE_PROFILE      Defaults to user-cache.
  EXPCAP_PROJECT_STATUS       Defaults to active. Use inactive to keep reporting separate for dormant projects.
  EXPCAP_INCLUDE_CLAUDE=1     Also add CLAUDE.md instructions.
  EXPCAP_SKIP_MILVUS_SYNC=1   Skip Milvus index sync.
USAGE
  exit 0
fi

cd "$PROJECT_ROOT"

export EXPCAP_STORAGE_PROFILE="${EXPCAP_STORAGE_PROFILE:-user-cache}"
export EXPCAP_HOME="${EXPCAP_HOME:-$HOME/.expcap}"

if [[ ! -d ".venv" ]]; then
  python3 -m venv .venv
fi

.venv/bin/pip install -e ".[milvus]"

scripts/install-codex-skill

INSTALL_ARGS=(install-project --workspace "$TARGET_WORKSPACE" --project-status "${EXPCAP_PROJECT_STATUS:-active}")
if [[ "${EXPCAP_INCLUDE_CLAUDE:-0}" == "1" ]]; then
  INSTALL_ARGS+=(--include-claude)
fi
scripts/expcap "${INSTALL_ARGS[@]}"

if [[ "${EXPCAP_SKIP_MILVUS_SYNC:-0}" != "1" ]]; then
  scripts/expcap sync-milvus --workspace "$TARGET_WORKSPACE" --include-shared
fi

scripts/expcap doctor --workspace "$TARGET_WORKSPACE"
