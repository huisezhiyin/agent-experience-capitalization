#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import datetime, timezone
import json
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import Any

PROJECT_ROOT = Path(__file__).resolve().parents[1]
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

from runtime.storage.fs_store import default_db_path, memory_root_for_workspace  # noqa: E402
from runtime.storage.sqlite_store import list_activation_logs  # noqa: E402
from runtime.core.hook_activity import load_recent_hook_events, parse_hook_timestamp, record_hook_event  # noqa: E402
from runtime.core.injection_materializer import render_hook_additional_context  # noqa: E402


TRIVIAL_PROMPTS = {
    "hi",
    "hello",
    "thanks",
    "thank you",
    "你好",
    "谢谢",
    "在吗",
}
NO_SAVE_MARKERS = (
    "不要记录",
    "不要保存",
    "别记录",
    "别保存",
    "don't save",
    "do not save",
    "no save",
)


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog="expcap-hook")
    subparsers = parser.add_subparsers(dest="event", required=True)

    for event in ("user-prompt-submit", "stop", "session-start", "pre-tool-use", "permission-request", "post-tool-use"):
        sub = subparsers.add_parser(event)
        sub.add_argument("--host", default="claude")
        sub.add_argument("--workspace")
        sub.add_argument("--task")
        sub.add_argument("--verification-status", default="unknown")
        sub.add_argument("--result-status", default="unknown")
        sub.add_argument("--result-summary")
    return parser.parse_args()


def _read_stdin_payload() -> dict[str, Any]:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        return {}
    return payload if isinstance(payload, dict) else {}


def _workspace(args: argparse.Namespace, payload: dict[str, Any]) -> Path:
    candidates = [
        args.workspace,
        payload.get("workspace"),
        payload.get("cwd"),
        payload.get("projectDir"),
    ]
    for candidate in candidates:
        if candidate:
            return Path(str(candidate)).resolve()
    return Path.cwd().resolve()


def _normalize_task(value: str | None) -> str | None:
    if value is None:
        return None
    normalized = " ".join(value.split())
    return normalized or None


def _task_for_prompt(args: argparse.Namespace, payload: dict[str, Any]) -> str | None:
    return _normalize_task(args.task or payload.get("prompt") or payload.get("task"))


def _session_start_task(args: argparse.Namespace, payload: dict[str, Any]) -> str:
    task = _normalize_task(args.task or payload.get("task") or payload.get("prompt"))
    return task or "session start: load project experience and workspace conventions"


def _payload_value(payload: dict[str, Any], *keys: str) -> str | None:
    for key in keys:
        value = payload.get(key)
        if value is None:
            continue
        normalized = _normalize_task(str(value))
        if normalized:
            return normalized
    return None


def _truncate(value: str | None, *, limit: int = 600) -> str | None:
    if not value:
        return None
    normalized = " ".join(str(value).split())
    if not normalized:
        return None
    if len(normalized) <= limit:
        return normalized
    return normalized[: limit - 1].rstrip() + "…"


def _nested_value(value: Any, *keys: str) -> Any:
    current = value
    for key in keys:
        if not isinstance(current, dict):
            return None
        current = current.get(key)
    return current


def _tool_name(payload: dict[str, Any]) -> str | None:
    return _payload_value(payload, "tool_name", "toolName", "tool")


def _tool_command(payload: dict[str, Any]) -> str | None:
    tool_input = payload.get("tool_input") or payload.get("toolInput") or {}
    if isinstance(tool_input, dict):
        return _truncate(
            str(
                tool_input.get("command")
                or tool_input.get("cmd")
                or tool_input.get("input")
                or tool_input.get("patch")
                or ""
            ),
            limit=800,
        )
    if isinstance(tool_input, str):
        return _truncate(tool_input, limit=800)
    return None


def _tool_response_status(payload: dict[str, Any]) -> str:
    response = payload.get("tool_response") or payload.get("toolResponse") or {}
    exit_code = _nested_value(response, "exit_code")
    if exit_code is None:
        exit_code = _nested_value(response, "exitCode")
    if exit_code is None:
        exit_code = _nested_value(response, "metadata", "exit_code")
    if exit_code is None:
        return "unknown"
    return "success" if str(exit_code) == "0" else "failed"


def _tool_error(payload: dict[str, Any]) -> str | None:
    response = payload.get("tool_response") or payload.get("toolResponse") or {}
    candidates: list[Any] = []
    if isinstance(response, dict):
        candidates.extend(
            [
                response.get("stderr"),
                response.get("error"),
                response.get("message"),
                _nested_value(response, "metadata", "stderr"),
            ]
        )
        if _tool_response_status(payload) == "failed":
            candidates.extend([response.get("stdout"), response.get("output")])
    elif isinstance(response, str):
        candidates.append(response)
    for candidate in candidates:
        text = _truncate(str(candidate), limit=800) if candidate is not None else None
        if text:
            return text
    return None


def _file_signals(*values: str | None) -> list[str]:
    seen: set[str] = set()
    files: list[str] = []
    pattern = re.compile(r"[\w./~$-]+\.(?:py|md|json|toml|ya?ml|txt|sh|lock|sqlite3|db)")
    for value in values:
        if not value:
            continue
        for match in pattern.findall(value):
            normalized = match.strip(".,:;()[]{}\"'")
            if normalized and normalized not in seen:
                files.append(normalized)
                seen.add(normalized)
    return files[:5]


def _guardrail_reason(tool_name: str | None, command: str | None) -> str | None:
    if not command:
        return None
    lowered = command.casefold()
    normalized = " ".join(lowered.split())
    is_git_write = "git add" in normalized or "git commit" in normalized

    if (tool_name or "").casefold() == "bash":
        destructive_patterns = (
            "rm -rf /",
            "rm -rf ~",
            "rm -rf $home",
            "sudo rm -rf",
            "git reset --hard",
            "git clean -fd",
            "git clean -xdf",
            "git checkout -- .",
            "git restore .",
        )
        if any(pattern in normalized for pattern in destructive_patterns):
            return "Blocked destructive shell or git command. Ask the user before running irreversible cleanup/reset operations."
        runtime_data_markers = (
            ".agent-memory",
            ".expcap/projects/",
            "/.expcap/projects/",
            "~/.expcap/projects/",
            "$home/.expcap/projects/",
            "codex/expcap-memory/",
            "/.codex/expcap-memory/",
            "index.sqlite3",
            "milvus.db",
            "milvus.openai",
            "milvus.local",
        )
        if is_git_write and any(marker in normalized for marker in runtime_data_markers):
            return (
                "Blocked attempt to include expcap local runtime data in git. "
                "Do not commit trace, episode, candidate, SQLite, or Milvus runtime data."
            )

    secret_markers = (
        "openai_api_key=",
        "api_key=",
        "access_token=",
        "secret_key=",
        "private_key=",
        "-----begin private key-----",
    )
    if any(marker in normalized for marker in secret_markers):
        return "Blocked apparent local secret or API key from being written through a tool call."
    if "add file: .env" in normalized or "update file: .env" in normalized:
        return "Blocked direct edit of .env; local credentials should not be managed by Codex hooks."
    return None


def _pre_tool_use_block_output(reason: str) -> dict[str, Any]:
    return {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": "deny",
            "permissionDecisionReason": reason,
        }
    }


def _permission_request_deny_output(reason: str) -> dict[str, Any]:
    return {
        "hookSpecificOutput": {
            "hookEventName": "PermissionRequest",
            "decision": {
                "behavior": "deny",
                "message": reason,
            },
        }
    }


def _recent_tool_evidence(workspace: Path) -> tuple[list[str], list[str]]:
    commands: list[str] = []
    errors: list[str] = []
    seen_commands: set[str] = set()
    seen_errors: set[str] = set()
    for item in load_recent_hook_events(workspace, limit=50):
        if item.get("event") != "post-tool-use":
            continue
        if item.get("command") == "progressive-recall":
            continue
        command = _truncate(str(item.get("command") or ""), limit=800)
        if command and command not in seen_commands:
            commands.append(command)
            seen_commands.add(command)
        error = _truncate(str(item.get("error") or ""), limit=800)
        if error and error not in seen_errors:
            errors.append(error)
            seen_errors.add(error)
        if len(commands) >= 5 and len(errors) >= 3:
            break
    return commands[:5], errors[:3]


def _latest_injection_context(workspace: Path) -> str:
    latest_path = memory_root_for_workspace(workspace) / "injections" / "latest.md"
    try:
        context = latest_path.read_text(encoding="utf-8")
    except OSError:
        return ""
    return context[:6000]


def _latest_activation_task(workspace: Path) -> str | None:
    activations = list_activation_logs(default_db_path(workspace), workspace=str(workspace), limit=20)
    for activation in activations:
        feedback = activation.get("feedback", {})
        if not feedback.get("help_signal"):
            task = _normalize_task(str(activation.get("task_query") or ""))
            if task:
                return task
    if activations:
        return _normalize_task(str(activations[0].get("task_query") or ""))
    return None


def _is_trivial_prompt(task: str | None) -> bool:
    if not task:
        return True
    lowered = task.casefold()
    if lowered in TRIVIAL_PROMPTS:
        return True
    return len(lowered) < 8 and len(lowered.split()) <= 2


def _cooldown_minutes(event: str) -> float:
    default = "10"
    if event == "stop":
        default = "15"
    raw = os.environ.get("EXPCAP_HOOK_COOLDOWN_MINUTES", default)
    try:
        return max(float(raw), 0.0)
    except ValueError:
        return float(default)


def _progressive_recall_cooldown_minutes() -> float:
    raw = os.environ.get("EXPCAP_HOOK_PROGRESSIVE_COOLDOWN_MINUTES", "10")
    try:
        return max(float(raw), 0.0)
    except ValueError:
        return 10.0


def _contains_no_save_signal(*values: str | None) -> bool:
    haystack = " ".join(value for value in values if value).casefold()
    return any(marker.casefold() in haystack for marker in NO_SAVE_MARKERS)


def _recent_duplicate_event(workspace: Path, *, event: str, task: str | None) -> dict[str, Any] | None:
    if not task:
        return None
    now = datetime.now(timezone.utc)
    cooldown = _cooldown_minutes(event)
    for item in load_recent_hook_events(workspace, limit=20):
        if item.get("event") != event:
            continue
        if item.get("status") != "success":
            continue
        if _normalize_task(str(item.get("task") or "")) != task:
            continue
        created_at = parse_hook_timestamp(item.get("created_at"))
        if created_at is None:
            continue
        age_minutes = (now - created_at).total_seconds() / 60.0
        if age_minutes <= cooldown:
            return {**item, "age_minutes": round(age_minutes, 2), "cooldown_minutes": cooldown}
    return None


def _recent_progressive_recall_duplicate(workspace: Path, *, signal: str) -> dict[str, Any] | None:
    now = datetime.now(timezone.utc)
    cooldown = _progressive_recall_cooldown_minutes()
    for item in load_recent_hook_events(workspace, limit=30):
        if item.get("event") != "post-tool-use":
            continue
        if item.get("status") != "progressive-recall":
            continue
        if item.get("reason") != signal:
            continue
        created_at = parse_hook_timestamp(item.get("created_at"))
        if created_at is None:
            continue
        age_minutes = (now - created_at).total_seconds() / 60.0
        if age_minutes <= cooldown:
            return {**item, "age_minutes": round(age_minutes, 2), "cooldown_minutes": cooldown}
    return None


def _run_expcap(command: list[str]) -> dict[str, Any]:
    completed = subprocess.run(
        command,
        cwd=PROJECT_ROOT,
        capture_output=True,
        text=True,
        check=True,
    )
    return json.loads(completed.stdout)


def _user_prompt_hook_output(result: dict[str, Any]) -> dict[str, Any]:
    summary = render_hook_additional_context(result.get("activation_view") or {})
    return {
        "continue": True,
        "suppressOutput": True,
        "hookSpecificOutput": {
            "hookEventName": "UserPromptSubmit",
            "additionalContext": summary,
        },
    }


def _json_continue_output(hook_event_name: str, *, additional_context: str = "") -> dict[str, Any]:
    return {
        "continue": True,
        "suppressOutput": True,
        "hookSpecificOutput": {
            "hookEventName": hook_event_name,
            "additionalContext": additional_context,
        },
    }


def _skip_output(reason: str, *, hook_event_name: str | None = None) -> dict[str, Any]:
    output: dict[str, Any] = {
        "continue": True,
        "suppressOutput": True,
        "stopReason": reason,
    }
    if hook_event_name:
        output["hookSpecificOutput"] = {
            "hookEventName": hook_event_name,
            "additionalContext": "",
        }
    return output


def _progressive_recall_context(view: dict[str, Any]) -> str:
    progressive = view.get("progressive_recall") if isinstance(view.get("progressive_recall"), dict) else {}
    reasons = progressive.get("trigger_reasons") if isinstance(progressive.get("trigger_reasons"), list) else []
    header = [
        "# expcap continuous runtime recall",
        "",
        "- injection_layer: `continuous_runtime_recall_injection`",
    ]
    if reasons:
        header.append("- trigger_reasons: " + ", ".join(str(reason) for reason in reasons))
    header.append("")
    return "\n".join(header) + render_hook_additional_context(view)


def _run_post_tool_progressive_recall(
    *,
    workspace: Path,
    command: str | None,
    error: str | None,
    tool_status: str,
) -> tuple[str, dict[str, Any] | None, str | None]:
    if tool_status != "failed" and not error:
        return "", None, None
    signal = _truncate(error or command or tool_status, limit=300)
    if not signal:
        return "", None, None
    duplicate = _recent_progressive_recall_duplicate(workspace, signal=signal)
    if duplicate:
        return "", {"triggered": False, "decision": {"skip_reason": "hook_duplicate_cooldown", **duplicate}}, signal

    task = _latest_activation_task(workspace) or _truncate(command, limit=180) or "post tool failure"
    recall_command = [
        str(PROJECT_ROOT / "scripts" / "expcap"),
        "progressive-recall",
        "--workspace",
        str(workspace),
        "--task",
        task,
        "--phase",
        "fix",
        "--cooldown-minutes",
        str(_progressive_recall_cooldown_minutes()),
        "--message",
        _truncate(f"PostToolUse observed failed command: {command}", limit=600) or "PostToolUse observed failed command.",
    ]
    if error:
        recall_command.extend(["--error", error])
    for file_signal in _file_signals(command, error):
        recall_command.extend(["--file", file_signal])

    try:
        result = _run_expcap(recall_command)
    except subprocess.CalledProcessError as exc:
        return "", {"triggered": False, "error": exc.stderr.strip() or exc.stdout.strip() or str(exc)}, signal

    view = result.get("activation_view") if isinstance(result.get("activation_view"), dict) else None
    selected_count = int(result.get("selected_count", 0) or 0)
    if result.get("triggered") and view and selected_count > 0:
        return _progressive_recall_context(view), result, signal
    return "", result, signal


def _record(
    workspace: Path,
    *,
    host: str,
    event: str,
    status: str,
    task: str | None,
    reason: str | None = None,
    command: str | None = None,
    result_summary: str | None = None,
    tool_name: str | None = None,
    tool_status: str | None = None,
    error: str | None = None,
) -> None:
    record_hook_event(
        workspace,
        {
            "host": host,
            "event": event,
            "status": status,
            "task": task,
            "reason": reason,
            "command": command,
            "result_summary": result_summary,
            "tool_name": tool_name,
            "tool_status": tool_status,
            "error": error,
        },
    )


def main() -> int:
    args = _parse_args()
    payload = _read_stdin_payload()
    workspace = _workspace(args, payload)

    try:
        if args.event == "session-start":
            source = _payload_value(payload, "source") or "unknown"
            task = _session_start_task(args, payload)
            duplicate = _recent_duplicate_event(workspace, event=args.event, task=task)
            if duplicate:
                context = _latest_injection_context(workspace)
                _record(
                    workspace,
                    host=args.host,
                    event=args.event,
                    status="skipped",
                    task=task,
                    reason=f"duplicate_cooldown:{duplicate['age_minutes']}/{duplicate['cooldown_minutes']}",
                )
                print(json.dumps(_json_continue_output("SessionStart", additional_context=context), ensure_ascii=False))
                return 0
            result = _run_expcap(
                [
                    str(PROJECT_ROOT / "scripts" / "expcap"),
                    "auto-start",
                    "--workspace",
                    str(workspace),
                    "--task",
                    task,
                ]
            )
            context = render_hook_additional_context(result.get("activation_view") or {})
            _record(
                workspace,
                host=args.host,
                event=args.event,
                status="success",
                task=task,
                reason=f"source:{source}",
                command="auto-start",
                result_summary=f"selected_count={result.get('selected_count', 0)}",
            )
            print(json.dumps(_json_continue_output("SessionStart", additional_context=context), ensure_ascii=False))
            return 0

        if args.event == "post-tool-use":
            tool_name = _tool_name(payload)
            command = _tool_command(payload)
            tool_status = _tool_response_status(payload)
            error = _tool_error(payload)
            _record(
                workspace,
                host=args.host,
                event=args.event,
                status="success",
                task=None,
                command=command,
                tool_name=tool_name,
                tool_status=tool_status,
                error=error,
            )
            additional_context, recall_result, recall_signal = _run_post_tool_progressive_recall(
                workspace=workspace,
                command=command,
                error=error,
                tool_status=tool_status,
            )
            if recall_result is not None:
                recall_status = "progressive-recall" if additional_context else "progressive-recall-skipped"
                result_summary = (
                    f"triggered={bool(recall_result.get('triggered'))};"
                    f"selected_count={recall_result.get('selected_count', 0)}"
                )
                decision = recall_result.get("decision") if isinstance(recall_result.get("decision"), dict) else {}
                _record(
                    workspace,
                    host=args.host,
                    event=args.event,
                    status=recall_status,
                    task=_latest_activation_task(workspace),
                    reason=recall_signal or decision.get("skip_reason") or recall_result.get("error"),
                    command="progressive-recall",
                    tool_name=tool_name,
                    tool_status=tool_status,
                    error=error,
                    result_summary=result_summary,
                )
            print(json.dumps(_json_continue_output("PostToolUse", additional_context=additional_context), ensure_ascii=False))
            return 0

        if args.event == "pre-tool-use":
            tool_name = _tool_name(payload)
            command = _tool_command(payload)
            reason = _guardrail_reason(tool_name, command)
            if reason:
                _record(
                    workspace,
                    host=args.host,
                    event=args.event,
                    status="blocked",
                    task=None,
                    reason=reason,
                    command=command,
                    tool_name=tool_name,
                )
                print(json.dumps(_pre_tool_use_block_output(reason), ensure_ascii=False))
                return 0
            _record(
                workspace,
                host=args.host,
                event=args.event,
                status="success",
                task=None,
                command=command,
                tool_name=tool_name,
            )
            return 0

        if args.event == "permission-request":
            tool_name = _tool_name(payload)
            command = _tool_command(payload)
            reason = _guardrail_reason(tool_name, command)
            if reason:
                _record(
                    workspace,
                    host=args.host,
                    event=args.event,
                    status="blocked",
                    task=None,
                    reason=reason,
                    command=command,
                    tool_name=tool_name,
                )
                print(json.dumps(_permission_request_deny_output(reason), ensure_ascii=False))
                return 0
            _record(
                workspace,
                host=args.host,
                event=args.event,
                status="success",
                task=None,
                command=command,
                tool_name=tool_name,
                reason=_payload_value(payload.get("tool_input") or {}, "description") if isinstance(payload.get("tool_input"), dict) else None,
            )
            return 0

        if args.event == "user-prompt-submit":
            task = _task_for_prompt(args, payload)
            if _is_trivial_prompt(task):
                _record(workspace, host=args.host, event=args.event, status="skipped", task=task, reason="trivial_or_empty_prompt")
                print(json.dumps(_skip_output("skip trivial or empty prompt", hook_event_name="UserPromptSubmit"), ensure_ascii=False))
                return 0
            duplicate = _recent_duplicate_event(workspace, event=args.event, task=task)
            if duplicate:
                _record(
                    workspace,
                    host=args.host,
                    event=args.event,
                    status="skipped",
                    task=task,
                    reason=f"duplicate_cooldown:{duplicate['age_minutes']}/{duplicate['cooldown_minutes']}",
                )
                print(json.dumps(_skip_output("skip duplicate prompt within cooldown", hook_event_name="UserPromptSubmit"), ensure_ascii=False))
                return 0
            result = _run_expcap(
                [
                    str(PROJECT_ROOT / "scripts" / "expcap"),
                    "auto-start",
                    "--workspace",
                    str(workspace),
                    "--task",
                    task,
                ]
            )
            _record(
                workspace,
                host=args.host,
                event=args.event,
                status="success",
                task=task,
                command="auto-start",
                result_summary=f"selected_count={result.get('selected_count', 0)}",
            )
            print(json.dumps(_user_prompt_hook_output(result), ensure_ascii=False))
            return 0

        task = _normalize_task(args.task or payload.get("task")) or _latest_activation_task(workspace)
        if not task:
            _record(workspace, host=args.host, event=args.event, status="skipped", task=None, reason="task_unresolved")
            print(json.dumps(_skip_output("skip stop hook without resolvable task"), ensure_ascii=False))
            return 0
        verification_status = _payload_value(payload, "verification_status", "verificationStatus") or args.verification_status
        result_status = _payload_value(payload, "result_status", "resultStatus") or args.result_status
        result_summary = _payload_value(payload, "result_summary", "resultSummary", "summary")
        if _contains_no_save_signal(task, args.result_summary, result_summary, str(payload.get("prompt") or ""), str(payload.get("task") or "")):
            _record(workspace, host=args.host, event=args.event, status="skipped", task=task, reason="explicit_no_save_signal")
            print(json.dumps(_skip_output("skip stop hook due to explicit no-save signal"), ensure_ascii=False))
            return 0
        duplicate = _recent_duplicate_event(workspace, event=args.event, task=task)
        if duplicate:
            _record(
                workspace,
                host=args.host,
                event=args.event,
                status="skipped",
                task=task,
                reason=f"duplicate_cooldown:{duplicate['age_minutes']}/{duplicate['cooldown_minutes']}",
            )
            print(json.dumps(_skip_output("skip duplicate stop within cooldown"), ensure_ascii=False))
            return 0
        command = [
            str(PROJECT_ROOT / "scripts" / "expcap"),
            "auto-finish",
            "--workspace",
            str(workspace),
            "--task",
            task,
            "--verification-status",
            verification_status,
            "--result-status",
            result_status,
            "--result-summary",
            args.result_summary or result_summary or f"hook auto-finish from {args.host} stop event",
        ]
        recent_commands, recent_errors = _recent_tool_evidence(workspace)
        for recent_command in recent_commands:
            command.extend(["--command", recent_command])
        for recent_error in recent_errors:
            command.extend(["--error", recent_error])
        result = _run_expcap(command)
        _record(
            workspace,
            host=args.host,
            event=args.event,
            status="success",
            task=task,
            command="auto-finish",
            result_summary=f"trace_id={result.get('trace', {}).get('trace_id')}",
        )
        print(json.dumps(_skip_output("stop hook completed auto-finish"), ensure_ascii=False))
        return 0
    except subprocess.CalledProcessError as error:
        stderr = error.stderr.strip() or error.stdout.strip() or str(error)
        task = _normalize_task(args.task or payload.get("prompt") or payload.get("task"))
        _record(workspace, host=args.host, event=args.event, status="error", task=task, reason=stderr)
        print(f"expcap-hook failed: {stderr}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
